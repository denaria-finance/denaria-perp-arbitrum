# Denaria Arbitrum Sepolia deployment template.
# Copy to .env and replace private or deployment-specific values before broadcasting.

# DEPLOYER
DEPLOYER_ADDR=0x61860509A5f05bDE458A5318D8E54654F60d0c38
PRIVATE_KEY=0xREPLACE_WITH_DEPLOYER_PRIVATE_KEY

# RPC AND EXPLORER VERIFICATION
ARBITRUM_SEPOLIA_RPC_URL=https://sepolia-rollup.arbitrum.io/rpc
ETHERSCAN_API_KEY=REPLACE_WITH_ETHERSCAN_API_KEY

# NETWORK AND PROTOCOL ADDRESSES
STABLECOIN=0xad78f7E737288e4a8CdF27d8e9c59B15399936EA
FEE_PROTOCOL_ADDR=0x1acA719546988cffe97265575c2C7F0D0aA488D8
MULTISIG=0x5631d6a73B36A9e8e8E3f0ecC1CbAB2F6Ed4BCE5

# CHAINLINK DATA STREAMS
VERIFIER_PROXY=0x2ff010DEbC1297f19579B4246cad07bd24F2488A
ARBITRUM_SEPOLIA_BTC_FEED_ID=0x00037da06d56d083fe599397a4769a042d63aa73dc4ef57709d31e9971a5b439
ORACLE_FEED_ID=0x00037da06d56d083fe599397a4769a042d63aa73dc4ef57709d31e9971a5b439
ORACLE_DESCRIPTION="BTC oracle"
ORACLE_MAX_TIME_DELTA=45
ORACLE_DECIMALS_STEPDOWN_FACTOR=10000000000

# Oracle address passed to the engine constructor. The periphery deploy script does NOT create an
# oracle and REVERTS if this is the zero address. To use a fresh oracle, deploy TWAPOracleMiddleware
# separately (see docs/DEPLOYMENT.md), verify + LINK-fund it, then set this to its address. The value
# below is the previous live oracle; redeploy a fresh one when the oracle sources have changed.
EXISTING_ORACLE=0x539937f3A18604E89f3AaafB13F6e417342c4b90

# STYLUS PRODUCTION ENGINE
# Set this after deploying and activating the perp-engine WASM program.
PERP_ENGINE=0x0000000000000000000000000000000000000000

# MARKET PARAMETERS
TICKER_ASSET_CURRENCY=0x3078353535333434326434323534343300000000000000000000000000000000
INTENDED_TICKER_USD_BTC=0x5553442d42544300000000000000000000000000000000000000000000000000

MMR_DECIMALS=1000000
MMR=40000
FEE_FRACTIONS_DECIMALS=1000000
FEE_FRONTEND=300000
FEE_LP=500000
TRADING_FEE_DECIMALS=1000000000000000000
TRADING_FEE=1000000000000000
FLAT_TRADING_FEE=120000000000000000
ORACLE_DECIMALS=100000000
EMA_PARAM=90000000
RATIO_DECIMALS=100000000
MIN_COLLATERAL_MOVEMENT=100000000000000000
STABLE_DECIMALS=1000000
DEPOSIT_THRESHOLD=100000000000
WITHDRAWAL_THRESHOLD=100000000000

# GOVERNANCE HANDOFF
# false keeps the operator key during bring-up. Set true only when the deploy/runbook
# includes the full engine, manager, and Vault role handoff sequence.
TRANSFER_ROLES=false
